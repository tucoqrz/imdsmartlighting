{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "title": "💡 Brilho dos Postes",
      "description": "Nível de brilho (0-100) de cada poste",
      "type": "timeseries",
      "gridPos": { "h": 14, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisLabel": "Brilho (%)",
            "drawStyle": "line",
            "fillOpacity": 0,
            "gradientMode": "none",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": true
          },
          "min": 0,
          "max": 100,
          "unit": "percent"
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "" },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT date_trunc('second', time_index) AS \"time\", entity_id, MAX(brightness) AS brightness FROM mtimdlampservice.etlamp WHERE $__timeFilter(time_index) GROUP BY 1, 2 ORDER BY 1 ASC",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "🌙 Luminosidade Ambiente",
      "description": "Nível de luz ambiente (lux) captado pelo sensor de cada poste",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "postgres", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisLabel": "Lux",
            "drawStyle": "line",
            "fillOpacity": 0,
            "gradientMode": "none",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": true
          },
          "min": 0,
          "unit": "lux"
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "" },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT date_trunc('second', time_index) AS \"time\", entity_id, MAX(ambient_light) AS ambient_light FROM mtimdlampservice.etlamp WHERE $__timeFilter(time_index) GROUP BY 1, 2 ORDER BY 1 ASC",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "🔴🟢 Status dos Postes (ON/OFF)",
      "description": "Estado atual de cada poste — ON ou OFF",
      "type": "table",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 10 },
      "datasource": { "type": "postgres", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "center",
            "cellOptions": { "type": "color-text" }
          },
          "mappings": [
            { "type": "value", "options": { "ON":  { "color": "green", "index": 0, "text": "🟢 ON" } } },
            { "type": "value", "options": { "OFF": { "color": "red",   "index": 1, "text": "🔴 OFF" } } }
          ]
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Status" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "ON":  { "color": "green", "text": "🟢 ON" } } },
                  { "type": "value", "options": { "OFF": { "color": "red",   "text": "🔴 OFF" } } }
                ]
              }
            ]
          },

            {
              "matcher": { "id": "byName", "options": "Movimento" },
              "properties": [
                {
                  "id": "mappings",
                  "value": [
                    {
                      "type": "value",
                      "options": {
                        "true":  { "color": "orange", "text": "🚶 Movimento" },
                        "false": { "color": "blue",   "text": "😴 Sem movimento" }
                      }
                    }
                  ]
                }
              ]
            }
          ]
      },
      "options": {
        "showHeader": true,
        "footer": { "show": false }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT t.entity_id AS \"Poste\", t.status AS \"Status\", t.brightness AS \"Brilho\", t.ambient_light AS \"Luz Ambiente\", t.motion_detected AS \"Movimento\", t.time_index AS \"Última Atualização\" FROM mtimdlampservice.etlamp t INNER JOIN (SELECT entity_id, MAX(time_index) AS max_time FROM mtimdlampservice.etlamp GROUP BY entity_id) latest ON t.entity_id = latest.entity_id AND t.time_index = latest.max_time WHERE t.active = true ORDER BY t.entity_id ASC",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "🚶 Detecção de Movimento",
      "description": "Histórico de detecção de movimento por poste",
      "type": "state-timeline",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 10 },
      "datasource": { "type": "postgres", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "dark-blue",  "value": null },
              { "color": "dark-blue",  "value": 0 },
              { "color": "orange",     "value": 1 }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "true":  { "color": "orange",    "index": 0, "text": "Movimento" } } },
            { "type": "value", "options": { "false": { "color": "dark-blue", "index": 1, "text": "Sem movimento" } } }
          ]
        },
        "overrides": []
      },
      "options": {
        "alignValue": "center",
        "mergeValues": true,
        "showValue": "auto",
        "rowHeight": 0.8
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "" },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT date_trunc('second', time_index) AS \"time\", entity_id, MAX(CASE WHEN motion_detected = true THEN 1 ELSE 0 END) AS motion_detected FROM mtimdlampservice.etlamp WHERE $__timeFilter(time_index) GROUP BY 1, 2 ORDER BY 1 ASC",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "📊 Brilho Médio por Poste",
      "description": "Média de brilho de cada poste no período selecionado",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "postgres", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "continuous-BlYlRd" },
          "min": 0,
          "max": 100,
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue",   "value": null },
              { "color": "green",  "value": 30 },
              { "color": "yellow", "value": 60 },
              { "color": "red",    "value": 85 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "minVizWidth": 0,
        "minVizHeight": 10,
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["mean"],
          "fields": "",
          "values": false
        },
        "showUnfilled": true
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "" },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT time_index AS \"time\", entity_id, brightness FROM mtimdlampservice.etlamp WHERE $__timeFilter(time_index) ORDER BY time_index ASC",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["fiware", "iot", "imd"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m"]
  },
  "timezone": "browser",
  "title": "IMD Smart Lighting",
  "uid": "imd-smart-lighting",
  "version": 1
}
